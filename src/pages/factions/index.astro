---
import { pageTitle, paths } from "../../config";
import Layout from "../../Layout.astro";
import { factions as strings } from "../../strings";
import { getFirstFactionSlug } from "../../util";

const firstFactionSlug = getFirstFactionSlug();
---

<Layout
    title={pageTitle(strings.title)}
    description={strings.description}
    slug={paths.factions}
    redirect={`${paths.factions}/${firstFactionSlug}`}
/>
