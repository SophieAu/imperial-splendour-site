---
import { getCollection } from "astro:content";
import { pageTitle, paths } from "../../config";
import Layout from "../../Layout.astro";
import { factions as strings } from "../../strings";

const factions = await getCollection("factions");
// Redirect to first faction alphabetically by slug
const first = factions.sort((a, b) => a.data.slug.localeCompare(b.data.slug))[0];

return Astro.rewrite(`${paths.factions}/${first.data.slug}`);
---

<Layout
    title={pageTitle(strings.title)}
    description={strings.description}
    slug={paths.factions}
    redirect={`${paths.factions}/${first.data.slug}`}
/>
