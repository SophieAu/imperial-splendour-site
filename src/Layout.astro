---
import Footer from "./components/HeaderFooter/Footer.astro";
import HeaderWrapper from "./components/HeaderFooter/HeaderWrapper.astro";
import { BASE_URL, FALLBACK_IMAGE } from "./config";
import { TWITTER_HANDLE } from "./thirdPartyConfig";
import { getImage } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import textureBg from "@assets/texture_bg.jpg";
import textureHeadfoot from "@assets/texture_headfoot.jpg";
import favicon from "@assets/favicon.png";

const textureBgWebp = await getImage({ src: textureBg, format: "webp" });
const textureBgJpg = await getImage({ src: textureBg, format: "jpeg" });
const textureHeadfootWebp = await getImage({ src: textureHeadfoot, format: "webp" });
const textureHeadfootJpg = await getImage({ src: textureHeadfoot, format: "jpeg" });
const faviconImage = await getImage({ src: favicon, format: "png" });

interface Props {
  title: string;
  description: string;
  slug: string;
  ogImage?: string;
  viewTransitions?: boolean;
  redirect?: string;
}

const { title, description, slug, ogImage, viewTransitions = false, redirect } = Astro.props;
const ogImageUrl = `${BASE_URL}${ogImage || FALLBACK_IMAGE}`;
const url = `${BASE_URL}/${slug}`;
---

<!doctype html>
<html lang="en" prefix="og: http://ogp.me/ns#">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={faviconImage.src} />
    <meta name="description" content={description} />

    <link rel="alternate" type="application/rss+xml" href="/rss.xml" />
    <link rel="canonical" href={url} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={url} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={TWITTER_HANDLE} />
    <meta name="twitter:creator" content={TWITTER_HANDLE} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:url" content={url} />

    <link href="https://fonts.googleapis.com/css?family=IM+Fell+English&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css?family=IM+Fell+English+SC&display=swap" rel="stylesheet" />

    <title>{title}</title>
    {viewTransitions && <ClientRouter />}

    {redirect && <meta http-equiv="refresh" content={`0; url=${redirect}`} />}
    <noscript>
      <style>
        @media (max-width: 991px) {
          main {
            padding-top: 0;
          }
        }
      </style>
    </noscript>
  </head>
  <body
    style={`--bg-jpg: url('${textureBgJpg.src}'); --bg-webp: url('${textureBgWebp.src}'); --headfoot-jpg: url('${textureHeadfootJpg.src}'); --headfoot-webp: url('${textureHeadfootWebp.src}')`}
  >
    <HeaderWrapper />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    font-size: 16px;

    /* colours */
    --color-header-footer-bg: #b19776;
    --color-link-hover: #5c4e3c;
    --color-blog-meta: #444;
    --color-main-bg: #f9eeda;
    --color-white: #fff;
    --color-black: black;

    /* fonts */
    --font-family-body: "IM FELL English", georgia, times, serif;
    --font-family-heading: "IM FELL English SC", georgia, serif;
    --font-headline: normal 3rem var(--font-family-heading);
    --font-headline-mobile: normal 2.25rem var(--font-family-heading);
    --font-body: normal 1.5rem var(--font-family-body);
    --font-button: normal 2.5rem / var(--download-button-height) var(--font-family-heading);
    --font-hero: normal 2.15rem var(--font-family-body);
    --font-info: normal 1.75rem var(--font-family-body);
    --font-blog-meta: italic 1.25rem var(--font-family-body);
    --font-input: normal 1rem var(--font-family-body);

    /* layout */
    --header-height: 4.5rem;
    --footer-height: 4.5rem;
    --footer-mobile-height: 6.5rem;
    --max-content-width: 65rem;
    --max-site-width: 100rem;
    --download-button-height: 6.25rem;
    --download-button-width: 18.125rem;

    /* breakpoints (for use in JS/inline; use media queries in CSS) */
    --bp-mobile-max: 991px;
    --bp-tablet-min: 992px;
    --bp-tablet-max: 1023px;
    --bp-desktop-min: 1024px;
  }

  html,
  body {
    border: 0;
    margin: 0;
    padding: 0;
  }

  img {
    object-fit: contain;
    width: 100%;
  }

  picture {
    line-height: 0;
  }

  h2 {
    font: var(--font-headline);
  }

  a {
    color: var(--color-black);
    text-decoration: underline;
  }

  a:hover {
    color: var(--color-link-hover);
  }

  a:hover > * {
    fill: var(--color-link-hover);
    opacity: 0.5;
  }

  body {
    background-color: var(--color-main-bg);
    background-image: image-set(var(--bg-webp) type("image/webp"), var(--bg-jpg) type("image/jpeg"));
    font: var(--font-body);
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    align-items: center;
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: var(--header-height) 1.5rem 0;
  }

  main > * {
    max-width: var(--max-content-width);
    width: 100%;
  }

  .headfoot {
    align-items: center;
    background-color: var(--color-header-footer-bg);
    background-image: image-set(var(--headfoot-webp) type("image/webp"), var(--headfoot-jpg) type("image/jpeg"));
    box-shadow:
      0 0 1.25rem 1rem rgba(142, 142, 142, 0.4),
      0 0 1.25rem 0.75rem rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    z-index: 99;
  }
</style>
