---
import { paths } from "../../config";
import { header as strings } from "../../strings";
import { getFirstFactionSlug } from "../../util";
import HeaderDesktop from "./HeaderDesktop.astro";
import HeaderMobile from "./HeaderMobile.svelte";

const firstFactionSlug = await getFirstFactionSlug();
const menuItems = strings.menuItems.map(item =>
    item.path === paths.factions ? { ...item, path: `${paths.factions}/${firstFactionSlug}` } : item
);
---

<HeaderDesktop {menuItems} />
<HeaderMobile {menuItems} client:load />
