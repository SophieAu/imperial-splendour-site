---
interface Props {
  title: string;
  date: Date;
  link?: string;
  as: "h1" | "h2";
}

const { title, date, link, as: As } = Astro.props;
const formattedDate = date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<header class="post-header">
  <As>{link ? <a href={link}>{title}</a> : title}</As>
  <p class="date">{formattedDate}</p>
</header>

<style>
  .post-header {
    display: grid;
    grid-gap: 1rem 1.5rem;
    grid-template-columns: repeat(2, auto);
  }

  h1,
  h1 a,
  h2,
  h2 a {
    font: var(--font-headline);
    margin: 0;
    text-decoration: none;
  }

  .date {
    color: var(--color-blog-meta);
    font: var(--font-blog-meta);
    margin: 0;
    padding: 0.5rem 0 0;
    text-align: right;
  }

  @media (max-width: 991px) {
    h1,
    h2 {
      grid-column: 1/3;
      grid-row: 2/3;
    }

    h1,
    h1 a,
    h2,
    h2 a {
      font: var(--font-headline-mobile);
    }

    .date {
      grid-column: 1/3;
      grid-row: 1/2;
    }
  }
</style>
